{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/cmgh-featured-courses",
	"version": "0.1.0",
	"title": "Cmgh Featured Courses",
	"category": "widgets",
	"icon": "courses",
	"description": "Displays a grid of featured courses from the custom database.",
	"example": {},
	"supports": {
		"align": true,
		"html": false
	},
	"attributes": {
        "limit": {
            "type": "number",
            "default": 6
        }
    },
	"textdomain": "cmgh-featured-courses",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
